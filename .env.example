# PostgreSQL Configuration
POSTGRES_USER=gqlfederation
POSTGRES_PASSWORD=gqlfederation
POSTGRES_DB=gqlfederation

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-change-in-production

# Gateway Configuration
QUERY_PLAN_CACHE_TTL=3600
MAX_QUERY_DEPTH=15
MAX_COMPLEXITY=1000
BATCH_SIZE=200
GRAYSCALE_PERCENT=10
GRAYSCALE_DURATION=300
GRAYSCALE_ERROR_THRESHOLD=5

# API Configuration
SUPERGRAPH_CACHE_TTL=300
